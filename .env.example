# Copy to `.env` (it is gitignored) and fill in.
#
# ---- LLM provider (pick ONE; the tool auto-detects from whichever key is set) ----
# Set the API key for the provider you use. To force a specific one, also set
# QSCREEN_PROVIDER. List options + see what's detected:
#     python3 qscreen_ingest.py --list-providers
#
# IMPORTANT: paste the key right after the matching "=" on its OWN variable — the
# provider must match the key. A Kimi key goes in MOONSHOT_API_KEY (NOT MINIMAX).
# The "# ..." note after each line is ignored, so `KEY=sk-123   # note` is fine.
MINIMAX_API_KEY=          # minimax     get a key: https://platform.minimax.io/
OPENROUTER_API_KEY=       # openrouter  get a key: https://openrouter.ai/keys
MOONSHOT_API_KEY=         # kimi (Kimi/Moonshot keys go HERE) https://platform.moonshot.ai/console/api-keys
OPENAI_API_KEY=           # openai      get a key: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=        # claude      get a key: https://console.anthropic.com/settings/keys
# LLM_API_KEY=            # generic fallback key for any provider / --provider custom

# ---- Local / offline models (NO API key) ----
# Run a model on your own laptop. Install a runtime, then just force its provider:
#   QSCREEN_PROVIDER=ollama         # ollama | mlx | lmstudio | llamacpp | jan | gpt4all
#   QSCREEN_MODEL=gemma2:2b         # the local model to use (Ollama example)
# Run a 270M model on a Mac with MLX (pip install mlx-lm; mlx_lm.server --model …):
#   QSCREEN_PROVIDER=mlx            # serves http://localhost:8080/v1, no key
#   QSCREEN_MODEL=mlx-community/gemma-3-270m-it-4bit
# Basic mode (deterministic-first; reads numbers from the PDF tables) auto-enables for local.
#   QSCREEN_GUIDED=1                # force Basic on (0 = force Pro, the big single prompt)
#   QSCREEN_BASE_URL=http://localhost:8080/v1    # only to override the host/port
# Fully offline (no model at all): pass --no-llm on the CLI / tick the box in the app.

# Optional: force the provider/model instead of auto-detecting.
# QSCREEN_PROVIDER=minimax        # cloud: minimax|openrouter|kimi|openai|anthropic(=claude)|custom
#                                 # local: ollama|mlx|lmstudio|llamacpp|jan|gpt4all
# QSCREEN_MODEL=MiniMax-M2        # override the default model for the chosen provider

# ---- Optional: only if you upload to a running QScreen API ----
INGEST_TOKEN=
QSCREEN_API_URL=http://localhost:3004
