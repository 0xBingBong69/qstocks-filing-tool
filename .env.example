# Copy to `.env` (it is gitignored) and fill in.
#
# ---- LLM provider (pick ONE; the tool auto-detects from whichever key is set) ----
# Set the API key for the provider you use. To force a specific one, also set
# QSCREEN_PROVIDER. List options any time:  python3 qscreen_ingest.py --list-providers
#
# Get a key from the link, then paste it after the matching "=".
MINIMAX_API_KEY=          # minimax     get a key: https://platform.minimax.io/
OPENROUTER_API_KEY=       # openrouter  get a key: https://openrouter.ai/keys
MOONSHOT_API_KEY=         # kimi        get a key: https://platform.moonshot.ai/console/api-keys
OPENAI_API_KEY=           # openai      get a key: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=        # claude      get a key: https://console.anthropic.com/settings/keys
# LLM_API_KEY=            # generic fallback key for any provider / --provider custom

# ---- Local / offline models (NO API key) ----
# Run a model on your own laptop. Install a runtime, then just force its provider:
#   QSCREEN_PROVIDER=ollama         # ollama | lmstudio | llamacpp | jan | gpt4all
#   QSCREEN_MODEL=gemma2:2b         # the local model to use (Ollama example)
# Guided mode (step-by-step, best for small models) auto-enables for local runtimes.
#   QSCREEN_GUIDED=1                # force guided on (0 = force the big single prompt)
#   QSCREEN_BASE_URL=http://localhost:11434/v1   # only to override the host/port

# Optional: force the provider/model instead of auto-detecting.
# QSCREEN_PROVIDER=minimax        # cloud: minimax|openrouter|kimi|openai|anthropic(=claude)|custom
#                                 # local: ollama|lmstudio|llamacpp|jan|gpt4all
# QSCREEN_MODEL=MiniMax-M2        # override the default model for the chosen provider

# ---- Optional: only if you upload to a running QScreen API ----
INGEST_TOKEN=
QSCREEN_API_URL=http://localhost:3004
