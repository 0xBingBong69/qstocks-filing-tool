# Copy to `.env` (it is gitignored) and fill in.
#
# ---- Required for extraction ----
# An LLM API key. OpenRouter is the default provider; MiniMax also works.
# OpenRouter: https://openrouter.ai/keys
# MiniMax: https://platform.minimax.io
OPENROUTER_API_KEY=
# (alternatively) MINIMAX_API_KEY=

# ---- Optional: only if you upload to a running QScreen API ----
INGEST_TOKEN=
QSCREEN_API_URL=http://localhost:3004